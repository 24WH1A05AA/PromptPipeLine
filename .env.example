# Prompt Pipeline — Environment Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Required ──

# OpenRouter API key — get one free at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use for all pipeline stages.
# Full list: https://openrouter.ai/models
# Recommended options:
#   openai/gpt-4o-mini           (fast, cheap, good quality)
#   google/gemma-4-31b-it:free   (free tier, Gemma 4 31B)
#   openai/gpt-3.5-turbo         (fast, very cheap)
MODEL=openai/gpt-4o-mini

# ── Optional ──

# Request timeout in seconds (default: 60)
# REQUEST_TIMEOUT=60

# Default temperature for generation, 0.0–2.0 (default: 0.7)
# DEFAULT_TEMPERATURE=0.7
